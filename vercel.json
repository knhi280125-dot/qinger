<!DOCTYPE html>
<html>
<head>
    <title>查詢老師資料</title>
    <meta charset="utf-8">
</head>
<body>
    <h1>查詢靜宜資管老師</h1>
    <form method="POST">
        <input type="text" name="keyword" placeholder="輸入老師名字關鍵字" value="{{ keyword }}">
        <button type="submit">查詢</button>
    </form>

    {% if teachers %}
    <table border="1" style="margin-top: 20px;">
        <tr>
            <th>老師姓名</th>
            <th>研究室</th>
        </tr>
        {% for t in teachers %}
        <tr>
            <td>{{ t.name }}</td>
            <td>{{ t.lab }}</td>
        </tr>
        {% endfor %}
    </table>
    {% elif keyword %}
    <p>找不到符合 "{{ keyword }}" 的老師。</p>
    {% endif %}

    <br>
    <a href="/">回到首頁</a>
</body>
</html>
